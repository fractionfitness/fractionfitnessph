# syntax=docker/dockerfile:1

FROM node:18.13-bullseye-slim as builder
WORKDIR '/app/client'
COPY --link ./client/package.json .
RUN npm install
COPY --link ./client .
RUN npm run build:prod

FROM node:18.13-bullseye-slim
ENV NODE_ENV production

WORKDIR '/app/client/dist'
COPY --link --chown=node:node --from=builder /app/client/dist .

WORKDIR '/app/api'
COPY --link ./api/package*.json .
RUN npm ci --only=production
COPY --link ./api .
EXPOSE 5000
CMD ["node", "index.js"]

# WILL NOT AUTOMATICALLY CONNECT TO POSTGRES IF BUILT AND RUN SINCE CURRENTLY NOT BEING
# USED IN A DOCKER COMPOSE FILE

# FOR REFERENCE OF DOCKERFILE TO MAXIMIZE BUILD PERFROMANCE WHILE IN DEV ENVIRONMENT
# WHILE THE PRODUCTION DOCKERFILE MINIMIZES BUILD LAYERS AND IMAGE SIZE

# IF GOING TO IMPLEMENT DOCKER COMPOSE TO RUN AND WATCH CLIENT, API, AND POSTGRES
# TOGETHER FOR DEVELOPMENT (INSTEAD OF RUNNING SEPARATE SCRIPTS FOR EACH), A DOCKERFILE
# NEEDS TO BE INSIDE OF EACH PROJECT, ENVIRONMENT MUST BE DEVELOPMENT, AND VOLUMES MUST
# BE USED IN DOCKER COMPOSE